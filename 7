document.addEventListener("DOMContentLoaded", () => {
    // Elements
    const sourceText = document.getElementById("source-text");
    const resultText = document.getElementById("result-text");
    const charCount = document.getElementById("char-count");
    const langPair = document.getElementById("lang-pair");
    const subject = document.getElementById("subject");
    const btnTranslate = document.getElementById("btn-translate");
    const btnClear = document.getElementById("btn-clear");
    const btnPaste = document.getElementById("btn-paste");
    const btnCopy = document.getElementById("btn-copy");
    const btnSwap = document.getElementById("btn-swap");
    const btnTerms = document.getElementById("btn-terms");
    const termsPanel = document.getElementById("terms-panel");
    const termsContent = document.getElementById("terms-content");
    const btnCloseTerms = document.getElementById("btn-close-terms");
    const historyList = document.getElementById("history-list");
    const btnClearHistory = document.getElementById("btn-clear-history");
    const modeTabs = document.querySelectorAll(".mode-tab");

    let currentMode = "general";
    let isTranslating = false;
    let history = JSON.parse(localStorage.getItem("translateHistory") || "[]");

    // Mode tabs
    modeTabs.forEach(tab => {
        tab.addEventListener("click", () => {
            modeTabs.forEach(t => t.classList.remove("active"));
            tab.classList.add("active");
            currentMode = tab.dataset.mode;
        });
    });

    // Character count
    sourceText.addEventListener("input", () => {
        const len = sourceText.value.length;
        charCount.textContent = `${len} / 10000 字符`;
        charCount.style.color = len > 9000 ? "#ef4444" : "";
    });

    // Clear
    btnClear.addEventListener("click", () => {
        sourceText.value = "";
        resultText.innerHTML = '<p class="placeholder-text">翻译结果将显示在这里...</p>';
        charCount.textContent = "0 字符";
    });

    // Paste
    btnPaste.addEventListener("click", async () => {
        try {
            const text = await navigator.clipboard.readText();
            sourceText.value = text;
            sourceText.dispatchEvent(new Event("input"));
        } catch (e) {
            showToast("无法访问剪贴板");
        }
    });

    // Copy
    btnCopy.addEventListener("click", () => {
        const text = resultText.innerText;
        if (!text || text === "翻译结果将显示在这里...") return;
        navigator.clipboard.writeText(text).then(() => showToast("✅ 已复制到剪贴板"));
    });

    // Swap languages
    btnSwap.addEventListener("click", () => {
        const val = langPair.value;
        if (val === "auto") return;
        const [src, tgt] = val.split("-");
        const swapped = `${tgt}-${src}`;
        for (const opt of langPair.options) {
            if (opt.value === swapped) {
                langPair.value = swapped;
                // Swap text content too
                const resultContent = resultText.innerText;
                if (resultContent && resultContent !== "翻译结果将显示在这里...") {
                    sourceText.value = resultContent;
                    sourceText.dispatchEvent(new Event("input"));
                    resultText.innerHTML = '<p class="placeholder-text">点击翻译...</p>';
                }
                showToast("🔄 已交换语言方向");
                return;
            }
        }
        showToast("不支持的语言方向");
    });

    // Translate (Streaming)
    btnTranslate.addEventListener("click", async () => {
        const text = sourceText.value.trim();
        if (!text) { showToast("请输入要翻译的文本"); return; }
        if (isTranslating) return;

        setTranslating(true);
        resultText.innerHTML = "";

        try {
            const response = await fetch("/api/translate/stream", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    text,
                    lang_pair: langPair.value,
                    mode: currentMode,
                    subject: subject.value
                })
            });

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let fullResult = "";

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;

                const chunk = decoder.decode(value, { stream: true });
                const lines = chunk.split("\n");

                for (const line of lines) {
                    if (line.startsWith("data: ")) {
                        try {
                            const data = JSON.parse(line.slice(6));
                            if (data.error) {
                                resultText.innerHTML = `<span style="color:#ef4444">❌ ${data.error}</span>`;
                                break;
                            }
                            if (data.text) {
                                fullResult += data.text;
                                resultText.innerText = fullResult;
                                resultText.scrollTop = resultText.scrollHeight;
                            }
                        } catch (e) { /* skip */ }
                    }
                }
            }

            // Save to history
            if (fullResult) {
                addHistory(text, fullResult, currentMode);
            }
        } catch (e) {
            resultText.innerHTML = `<span style="color:#ef4444">❌ 翻译失败: ${e.message}</span>`;
        } finally {
            setTranslating(false);
        }
    });

    // Keyboard shortcut: Ctrl+Enter to translate
    sourceText.addEventListener("keydown", (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
            btnTranslate.click();
        }
    });

    // Extract Terms
    btnTerms.addEventListener("click", async () => {
        const text = sourceText.value.trim();
        if (!text) { showToast("请先输入文本"); return; }

        termsContent.innerHTML = "<p>正在提取术语...</p>";
        termsPanel.style.display = "block";

        try {
            const res = await fetch("/api/detect-terms", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ text, subject: subject.value })
            });
            const data = await res.json();

            if (data.terms && data.terms.length > 0) {
                let html = "<table><tr><th>术语原文</th><th>翻译</th></tr>";
                data.terms.forEach(t => {
                    html += `<tr><td>${t.term}</td><td>${t.translation}</td></tr>`;
                });
                html += "</table>";
                termsContent.innerHTML = html;
            } else {
                termsContent.innerHTML = "<p>未检测到专业术语</p>";
            }
        } catch (e) {
            termsContent.innerHTML = `<p style="color:#ef4444">提取失败: ${e.message}</p>`;
        }
    });

    btnCloseTerms.addEventListener("click", () => {
        termsPanel.style.display = "none";
    });

    // History
    function addHistory(source, result, mode) {
        const item = {
            source: source.substring(0, 100),
            result: result.substring(0, 100),
            mode,
            time: new Date().toLocaleString("zh-CN"),
            fullSource: source,
            fullResult: result
        };
        history.unshift(item);
        if (history.length > 20) history.pop();
        localStorage.setItem("translateHistory", JSON.stringify(history));
        renderHistory();
    }

    function renderHistory() {
        if (history.length === 0) {
            historyList.innerHTML = '<p class="placeholder-text">暂无翻译历史</p>';
            return;
        }
        const modeLabels = {
            general: "通用", academic: "学术", daily: "日常", email: "邮件", polish: "润色"
        };
        historyList.innerHTML = history.map((h, i) => `
            <div class="history-item" data-index="${i}">
                <div class="meta">${h.time} · ${modeLabels[h.mode] || h.mode}</div>
                <div class="preview">${h.source}...</div>
            </div>
        `).join("");

        historyList.querySelectorAll(".history-item").forEach(el => {
            el.addEventListener("click", () => {
                const idx = el.dataset.index;
                const item = history[idx];
                sourceText.value = item.fullSource;
                resultText.innerText = item.fullResult;
                sourceText.dispatchEvent(new Event("input"));
            });
        });
    }

    btnClearHistory.addEventListener("click", () => {
        history = [];
        localStorage.removeItem("translateHistory");
        renderHistory();
    });

    function setTranslating(state) {
        isTranslating = state;
        btnTranslate.disabled = state;
        btnTranslate.querySelector(".btn-text").style.display = state ? "none" : "inline";
        btnTranslate.querySelector(".btn-loading").style.display = state ? "inline" : "none";
    }

    function showToast(msg) {
        const toast = document.createElement("div");
        toast.className = "toast";
        toast.textContent = msg;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
    }

    // Init
    renderHistory();
});
